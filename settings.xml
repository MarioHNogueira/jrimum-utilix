<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                          https://maven.apache.org/xsd/settings-1.0.0.xsd">
	<localRepository />
	<interactiveMode />
	<offline />
	<pluginGroups />
	<servers>
		<server>
			<id>s3.releases</id>
			<username>${env.mvn_repo_user}</username>
			<password>${env.S3_PASSWORD}</password>
		</server>
		<server>
			<id>s3.snapshots</id>
			<username>${env.mvn_repo_user}</username>
			<password>${env.S3_PASSWORD}</password>
		</server>
		<server>
			<id>github</id>
			<username>${env.GITHUB_OWNER}</username>
			<password>${env.GITHUB_TOKEN}</password>
		</server>
	</servers>
	<mirrors />
	<proxies />
	<profiles>
		<profile>
			<id>clue-releases</id>
			<repositories>
				<repository>
					<id>central</id>
					<name>Maven Repository Switchboard</name>
					<url>https://repo1.maven.org/maven2</url>
					<layout>default</layout>
					<snapshots>
						<enabled>false</enabled>
					</snapshots>
				</repository>
				<repository>
					<id>s3.releases</id>
					<name>AWS S3 Releases Repository</name>
					<url>s3://br.com.clueit.mvn.repo/release</url>
				</repository>
				<repository>
					<id>s3.snapshots</id>
					<name>AWS S3 Releases Repository</name>
					<url>s3://br.com.clueit.mvn.repo/snapshot</url>
				</repository>
				<repository>
					<id>jrimum.org</id>
					<url>http://jrimum.org/maven/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</repository>
			</repositories>
		</profile>
	</profiles>
	<activeProfiles>
		<activeProfile>clue-releases</activeProfile>
	</activeProfiles>
</settings>